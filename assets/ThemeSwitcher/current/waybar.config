[
  {
    "reload_style_on_change": true,
    "spacing": "0",
    "mode": "dock",
    "position": "top",
    "margin-top": 10,

    "modules-left": [
    ],

    "modules-center": [
      "tray",
      "cpu",
      "memory",
      "disk",
      "network",
      "bluetooth",
      "custom/updates", 
      "custom/monitor-toggle",
      "ext/workspaces",
      "wireplumber",
      "battery",
      "idle_inhibitor",
      "custom/weather",
      "clock",
      "dwl/window",
    ],

    "modules-right": [
    ],

    "idle_inhibitor": {
      "format": " {icon} ",
      "format-icons": {
        "activated": "ÔĀģ",
        "deactivated": "ÔĀį"
      },
    },

    "battery": {
      "format": "{icon}",
      "format-alt": "{icon} {capacity}%",
      "format-charging": "ůĪä¶",
      "format-icons": [
        "ÔČĄ",
        "ÔČÉ",
        "ÔČā",
        "ÔČĀ",
        "ÔČÄ"
      ],
      "format-plugged": "Ôá¶",
      "states": {
        "critical": 15,
        "good": 95,
        "warning": 30
      },
      "tooltip": true,
      "tooltip-format": "{timeTo}
Health: {health}%
Usage: {power:0.1f}W
Cycles: {cycles}
Capacity: {capacity}%"
    },

    "bluetooth": {
      "controller": "hci0",
      "format": "{icon}",
      "format-alt": "{icon} {device_battery_percentage}%",
      "format-icons": {
        "no-controller": "ůį•ä",
        "connected": "Ôäď",
        "disabled": "ůįā≤",
        "discovering": "ůįāĪ",
        "on": "ůįāĮ",
        "off": "ůįā≤"
      },
      "on-click-right": "kitty -T BTUI bluetui",
      "tooltip-format": "{controller_alias}	{controller_address}

{num_connections} connected",
      "tooltip-format-connected": "{controller_alias}	{controller_address}

{num_connections} connected

{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}	{device_address}",
      "tooltip-format-enumerate-connected-battery": "{device_alias}	{device_address}	{device_battery_percentage}%"
    },

    "clock": {
      "actions": {
        "on-click-right": "mode",
        "on-scroll-down": "shift_down",
        "on-scroll-up": "shift_up"
      },
      "calendar": {
        "format": {
          "days": "<span color='#ecc6d9'><b>{}</b></span>",
          "months": "<span color='#ffead3'><b>{}</b></span>",
          "today": "<span color='#ff6699'><b>{}</b></span>",
          "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
          "weeks": "<span color='#99ffdd'><b>W{}</b></span>"
        },
        "mode": "month",
        "mode-mon-col": 3,
        "on-scroll": 1,
        "weeks-pos": "right"
      },
      "format": "ÔÄó {:%H:%M}",
      "format-alt": "Ó™į {:%a %d |  %H:%M}",
      "tooltip-format": "<tt><big>{:%b | %d | %Y}</big>

<small>{calendar}</small></tt>"
    },

    "cpu": {
      "format": "Ôíľ",
      "format-alt": "Ôíľ {usage}%",
      "format-icons": [
        "‚ĖĀ",
        "‚Ėā",
        "‚ĖÉ",
        "‚ĖĄ",
        "‚ĖÖ",
        "‚ĖÜ",
        "‚Ėá",
        "‚Ėą"
      ],
      "on-click-right": "kitty -T BTOP btop",
      "tooltip": true,
      "tooltip-format": "min: {min_frequency}"
    }, 

    "custom/monitor-toggle": {
      "format": "ůįćļ",
      "on-click": "wlr-randr --output HDMI-A-2 --on --pos 5120,0",
      "on-click-right": "wlr-randr --output HDMI-A-2 --off",
      "tooltip": true,
      "tooltip-format": "Left click: turn on | Right click: turn off"
    },

    "custom/power": {
      "format": "‚ŹĽ",
      "on-click": "wlogout -l ~/.config/wlogout/layout -s ~/.config/wlogout/style.css",
      "tooltip": false
    },

    "custom/weather": {
      "exec": "status-weather",
      "format": "{}",
      "interval": 30,
      "return-type": "json",
      "tooltip": true
    },

    "custom/updates": {
      "exec": "~/.local/bin/check-for-updates",
      "format": "{icon}",
      "format-alt": "{icon} {text}",
      "return-type": "json",
      "format-icons": {
        "available": "Ôďł",
        "unavailable": "ůįŹĖ",
      },
      "interval": 3600,
      "tooltip": true,
      "on-click-right": "kitty -T BTUI -H doas xbps-install -Syu"
    },

    "disk": {
      "swap-icon-label": false,
      "format": "ÔÉá",
      "format-alt": "ÔÉá {used}",
      "interval": 3600,
      "on-click-right": "kitty -T GDU gdu -d",
      "tooltip-format": "Available: {free} | {percentage_free}%
Used: {used} | {percentage_used}%"
    },

    "dwl/window": {
      "format": "{layout}",
      "menu": "on-click",
      "menu-actions": {
        "centerTiling": "mmsg -l CT",
        "deck": "mmsg -l K",
        "grid": "mmsg -l G",
        "monocle": "mmsg -l M",
        "rightTiling": "mmsg -l RT",
        "scrolling": "mmsg -l S",
        "tgmix": "mmsg -l TG",
        "tiling": "mmsg -l T",
        "verticalDeck": "mmsg -l VK",
        "verticalGrid": "mmsg -l VG",
        "verticalScrolling": "mmsg -l VS",
        "verticalTiling": "mmsg -l VT"
      },
      "menu-file": "$HOME/.config/waybar/mango-menu.xml",
      "rewrite": {
        "CT": "CTIL",
        "G": "GRID",
        "K": "DECK",
        "M": "MONO",
        "RT": "RTIL",
        "S": "SCRL",
        "T": "TILE",
        "TG": "TGMX",
        "VG": "VGRD",
        "VK": "VDCK",
        "VS": "VSCR",
        "VT": "VTIL"
      }
    },

    "ext/workspaces": {
      "active-only": false,
      "format": "{icon}",
      "format-icons": {
        "urgent": "ůįÄ¶"
      },
      "ignore-hidden": false,
      "on-click": "activate",
      "on-click-right": "deactivate",
      "sort-by-id": true
    },

    "memory": {
      "format": "ÓŅÖ",
      "format-alt": "ÓŅÖ  {used:0.1f}G",
      "format-icons": [
        "‚ĖĀ",
        "‚Ėā",
        "‚ĖÉ",
        "‚ĖĄ",
        "‚ĖÖ",
        "‚ĖÜ",
        "‚Ėá",
        "‚Ėą"
      ],
      "on-click-right": "kitty -T BTOP btop",
      "tooltip-format": "Mem: {used}/{total} GiB | {percentage}%
Swap: {swapUsed}/{swapTotal} GiB | {swapPercentage}%"
    },

    "network": {
      "format-alt": "{icon} |  {bandwidthUpBytes} |  {bandwidthDownBytes}",
      "format-disconnected": "ůį§ģ",
      "format-ethernet": "{icon}",
      "format-icons": {
        "ethernet": [
          "ůįąÄ"
        ],
        "wifi": [
          "ůį§Į",
          "ůį§ü",
          "ůį§Ę",
          "ůį§•",
          "ůį§®"
        ]
      },
      "format-wifi": "{icon}",
      "format-wifi-alt": "{icon} {signalStrength}%",
      "on-click-right": "kitty -T IMPALA impala",
      "tooltip-format": "{ifname} via {gwaddr} ůįäó",
      "tooltip-format-disconnected": "ůį§ģ Disconnected",
      "tooltip-format-ethernet": "IP: {ipaddr}
Down: ÔźČ {bandwidthDownBytes}
Up: Ôźä {bandwidthUpBytes}",
      "tooltip-format-wifi": "{icon} {essid} ({signalStrength}%)
IP: {ipaddr}
Down: ÔźČ {bandwidthDownBytes}
Up: Ôźä {bandwidthUpBytes}"
    },

    "wireplumber": {
      "format": "{icon}",
      "format-alt": "{icon} {volume}%",
      "format-bluetooth": "{volume}% {icon}ÔäĒ {format_source}",
      "format-bluetooth-muted": "Ôö© {icon}ÔäĒ {format_source}",
      "format-icons": {
        "default": [
          "ÔÄ¶",
          "ÔÄß",
          "ÔÄ®"
        ],
        "hands-free": "ÔĖź",
        "headphone": "ÔÄ•",
      },
      "format-muted": "ůįĚü {format_source}",
      "format-source": "{volume}% ÔĄį",
      "format-source-muted": "ÔĄĪ",
      "on-click-right": "kitty -T WIREMIX wiremix"
    },

    "temperature": {
      "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
      "input-filename": "temp1_input",
      "critical-threshold": 80,
      "format": "ÔčČ  {temperatureC}¬įC",
      "interval": 5
    },

    "tray": {
      "icon-size": 21,
      "spacing": 10,
      "show-passive-items": true,
      "icons": {
        "blueman": "bluetooth",
        "bluez": "bluetooth",
      },
    },
   }
]